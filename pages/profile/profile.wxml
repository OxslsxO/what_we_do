<view class="page">
  <view class="hero-shell">
    <view class="hero-glow hero-glow-left"></view>
    <view class="hero-glow hero-glow-right"></view>

    <view class="hero-card">
      <view class="hero-kicker">My Daily Space</view>
      <view class="hero-title">我的</view>
      <view class="hero-desc">
        这里收着你的记录、收藏、关系和设置。它不是资料页，而是你在《今天干点啥》里的生活后台。
      </view>
    </view>
  </view>

  <view class="section">
    <view class="profile-card">
      <view class="profile-top">
        <view class="avatar-shell">
          <image src="{{userInfo.avatar}}" mode="aspectFill" class="avatar-image"></image>
        </view>
        <view class="profile-main">
          <view class="profile-name">{{userInfo.name}}</view>
          <view class="profile-desc">{{userInfo.desc}}</view>
        </view>
        <button class="edit-button btn-primary mini-btn" bindtap="goToEditProfile" hover-class="hover-scale">{{loggedIn ? '编辑资料' : '去登录'}}</button>
      </view>

      <view class="stats-row">
        <view class="stat-card">
          <view class="stat-value">{{userInfo.activities || 0}}</view>
          <view class="stat-label">参与次数</view>
        </view>
        <view class="stat-card">
          <view class="stat-value">{{userInfo.friends || 0}}</view>
          <view class="stat-label">关系数量</view>
        </view>
        <view class="stat-card">
          <view class="stat-value">{{userInfo.points || 0}}</view>
          <view class="stat-label">成长积分</view>
        </view>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-head">
      <view class="section-title">我的内容</view>
    </view>
    <view class="menu-card glass-card">
      <view class="menu-item" bindtap="goToMyPosts" hover-class="hover-scale">
        <view class="menu-icon">📝</view>
        <view class="menu-copy">
          <view class="menu-title">我的帖子</view>
          <view class="menu-desc">把今天发布过的内容都翻出来看看</view>
        </view>
        <view class="menu-arrow">→</view>
      </view>
      <view class="menu-item" bindtap="goToLiked" hover-class="hover-scale">
        <view class="menu-icon">💞</view>
        <view class="menu-copy">
          <view class="menu-title">关系空间</view>
          <view class="menu-desc">去看邀请、动作、回应和共同回忆</view>
        </view>
        <view class="menu-arrow">→</view>
      </view>
      <view class="menu-item" bindtap="goToSaved" hover-class="hover-scale">
        <view class="menu-icon">⭐</view>
        <view class="menu-copy">
          <view class="menu-title">我的收藏</view>
          <view class="menu-desc">收好的灵感、照片和想回去再看的记录</view>
        </view>
        <view class="menu-arrow">→</view>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-head">
      <view class="section-title">系统与支持</view>
    </view>
    <view class="menu-card glass-card">
      <view class="menu-item" bindtap="goToSettings" hover-class="hover-scale">
        <view class="menu-icon">⚙️</view>
        <view class="menu-copy">
          <view class="menu-title">设置</view>
          <view class="menu-desc">管理提醒、隐私和本地草稿</view>
        </view>
        <view class="menu-arrow">→</view>
      </view>
      <view class="menu-item" bindtap="goToHelp" hover-class="hover-scale">
        <view class="menu-icon">❓</view>
        <view class="menu-copy">
          <view class="menu-title">帮助与反馈</view>
          <view class="menu-desc">先看常见问题，再把建议反馈给我们</view>
        </view>
        <view class="menu-arrow">→</view>
      </view>
      <view class="menu-item" bindtap="goToAbout" hover-class="hover-scale">
        <view class="menu-icon">ℹ️</view>
        <view class="menu-copy">
          <view class="menu-title">关于我们</view>
          <view class="menu-desc">了解这个小程序现在做到哪里，也要去哪里</view>
        </view>
        <view class="menu-arrow">→</view>
      </view>
    </view>
  </view>

  <view class="section footer-section">
    <button class="logout-btn-small" bindtap="logout" hover-class="hover-opacity">{{loggedIn ? '退出登录' : '前往登录'}}</button>
  </view>
</view>
