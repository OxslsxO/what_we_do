.page {
  min-height: 100vh;
  padding: 32rpx 24rpx 48rpx;
  box-sizing: border-box;
}

/* Hero Section */
.hero-shell {
  position: relative;
  margin-bottom: 40rpx;
}

.hero-glow {
  position: absolute;
  width: 240rpx;
  height: 240rpx;
  border-radius: var(--radius-round);
  filter: blur(50rpx);
  opacity: 0.4;
  z-index: -1;
  animation: pulseGlow 8s infinite alternate;
}

@keyframes pulseGlow {
  0% { transform: scale(1); opacity: 0.3; }
  100% { transform: scale(1.2); opacity: 0.5; }
}

.hero-glow-left {
  top: -20rpx;
  left: -20rpx;
  background: var(--primary-light);
}

.hero-glow-right {
  bottom: -20rpx;
  right: -20rpx;
  background: var(--secondary-light);
}

.hero-card {
  position: relative;
  padding: 40rpx 36rpx;
  border-radius: var(--radius-lg);
  background: 
    url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='160' height='160'><path d='M10,30 C40,10 60,60 90,30' fill='none' stroke='%23D0BA9B' stroke-width='3' stroke-linecap='round' opacity='0.3'/><circle cx='130' cy='45' r='3.5' fill='%23D0BA9B' opacity='0.4'/><path d='M25,120 Q45,150 70,115' fill='none' stroke='%23D0BA9B' stroke-width='3' stroke-linecap='round' opacity='0.3'/></svg>") right top no-repeat,
    linear-gradient(135deg, rgba(246, 239, 228, 0.98) 0%, rgba(235, 224, 208, 0.95) 100%);
  border: 1rpx solid rgba(225, 210, 190, 0.6);
  box-shadow: var(--shadow-soft);
  backdrop-filter: blur(16rpx);
}

.hero-kicker {
  font-size: 20rpx;
  color: var(--primary);
  letter-spacing: 4rpx;
  text-transform: uppercase;
  font-weight: 600;
}

.hero-title {
  margin-top: 8rpx;
  font-size: 48rpx;
  font-weight: bold;
  color: var(--text-main);
  letter-spacing: -1rpx;
}

.hero-desc {
  margin-top: 16rpx;
  font-size: 25rpx;
  line-height: 1.6;
  color: var(--text-sub);
}

/* Profile Card */
.profile-card {
  padding: 36rpx 32rpx;
  border-radius: var(--radius-md);
  background: var(--card-bg-gradient);
  border: 1rpx solid var(--border-light);
  box-shadow: var(--shadow-soft);
  backdrop-filter: blur(10rpx);
}

.profile-top {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.avatar-shell {
  width: 110rpx;
  height: 110rpx;
  border-radius: var(--radius-round);
  padding: 5rpx;
  background: var(--primary-gradient);
  box-shadow: var(--shadow-primary);
  flex-shrink: 0;
}

.avatar-image {
  width: 100%;
  height: 100%;
  border-radius: var(--radius-round);
  background: #fff;
}

.profile-main {
  flex: 1;
  min-width: 0;
}

.profile-name {
  font-size: 34rpx;
  font-weight: bold;
  color: var(--text-main);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.profile-desc {
  margin-top: 6rpx;
  font-size: 23rpx;
  color: var(--text-sub);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.mini-btn {
  padding: 0 20rpx !important;
  height: 56rpx !important;
  line-height: 56rpx !important;
  font-size: 22rpx !important;
  flex-shrink: 0;
}

/* Stats Row */
.stats-row {
  display: flex;
  gap: 16rpx;
  margin-top: 36rpx;
}

.stat-card {
  flex: 1;
  background: rgba(255, 255, 255, 0.45);
  padding: 20rpx 10rpx;
  border-radius: var(--radius-sm);
  text-align: center;
  border: 1rpx solid rgba(255, 255, 255, 0.6);
}

.stat-value {
  font-size: 34rpx;
  font-weight: bold;
  color: var(--primary);
}

.stat-label {
  font-size: 21rpx;
  color: var(--text-sub);
  margin-top: 6rpx;
}

/* Sections */
.section {
  margin-top: 40rpx;
}

.section-head {
  margin-bottom: 20rpx;
  padding: 0 8rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--text-main);
}

/* Menu Card */
.glass-card {
  background: var(--card-bg-gradient);
  border: 1rpx solid var(--border-light);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-soft);
  backdrop-filter: blur(10rpx);
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid rgba(225, 210, 190, 0.2);
  transition: all 0.2s ease;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  width: 68rpx;
  height: 68rpx;
  border-radius: 18rpx;
  background: rgba(255, 154, 118, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

.menu-copy {
  flex: 1;
}

.menu-title {
  font-size: 29rpx;
  font-weight: 600;
  color: var(--text-main);
}

.menu-desc {
  margin-top: 6rpx;
  font-size: 23rpx;
  color: var(--text-sub);
  line-height: 1.5;
}

.menu-arrow {
  font-size: 26rpx;
  color: var(--text-light);
  font-weight: bold;
}

/* Footer Section */
.footer-section {
  padding: 60rpx 0 80rpx;
  text-align: center;
}

.logout-btn-small {
  display: inline-block;
  min-width: 240rpx;
  height: 76rpx;
  line-height: 76rpx;
  border-radius: var(--radius-round);
  background: linear-gradient(135deg, #A67C52 0%, #8E6A46 100%);
  color: #fff !important;
  font-size: 26rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 20rpx rgba(142, 106, 70, 0.25);
  border: none;
  padding: 0 40rpx;
}

/* Animations */
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(12rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.section {
  animation: fadeIn 0.5s ease-out both;
}

.section:nth-child(2) { animation-delay: 0.1s; }
.section:nth-child(3) { animation-delay: 0.15s; }
.section:nth-child(4) { animation-delay: 0.2s; }
