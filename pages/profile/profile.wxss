/* 全局样式 */
.container {
  background-color: #FFFAF5;
  min-height: 100vh;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
}

/* 头部区域 */
.header {
  /* 蓝色渐变背景 */
  background: linear-gradient(135deg, #4080FF, #0066CC);
  padding: 40rpx 0;
  border-radius: 0 0 30rpx 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.1);
}

.user-info {
  display: flex;
  align-items: center;
  padding: 0 30rpx;
  gap: 20rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid white;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.2);
  transition: all 0.3s ease-in-out;
}

.avatar:hover {
  transform: scale(1.05);
  box-shadow: 0 6rpx 16rpx rgba(0,0,0,0.3);
}

.user-details {
  flex: 1;
}

.username {
  font-size: 32rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 8rpx;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.2);
}

.user-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.4;
}

.edit-btn {
  padding: 10rpx 24rpx;
  background-color: rgba(255,255,255,0.2);
  border: 2rpx solid rgba(255,255,255,0.4);
  border-radius: 24rpx;
  font-size: 24rpx;
  color: white;
  transition: all 0.2s ease-in-out;
}

.edit-btn:active {
  transform: scale(0.98);
  background-color: rgba(255,255,255,0.3);
}

.edit-btn:hover {
  background-color: rgba(255,255,255,0.3);
  transform: translateY(-2rpx);
}

/* 统计栏 */
.stats {
  background-color: white;
  margin: 20rpx 20rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
  display: flex;
  justify-content: space-around;
  padding: 30rpx 0;
  transition: all 0.3s ease-in-out;
}

.stats:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 6rpx 16rpx rgba(0,0,0,0.08);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 20rpx;
}

.stat-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 8rpx;
  transition: all 0.3s ease-in-out;
}

.stat-item:hover .stat-value {
  color: #4080FF;
  transform: scale(1.1);
}

.stat-label {
  font-size: 24rpx;
  color: #999999;
  text-align: center;
}

/* 菜单区域 */
.menu-section {
  background-color: white;
  margin: 20rpx 20rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
  overflow: hidden;
  transition: all 0.3s ease-in-out;
}

.menu-section:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 6rpx 16rpx rgba(0,0,0,0.08);
}

.menu-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  padding: 20rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
  background-color: #f9f9f9;
}

.menu-items {
  padding: 10rpx 0;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 25rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
  transition: all 0.2s ease-in-out;
  position: relative;
  overflow: hidden;
}

.menu-item::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 4rpx;
  background: linear-gradient(135deg, #FF6B8B, #FF8FA3);
  opacity: 0;
  transition: opacity 0.2s ease-in-out;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background-color: #f5f5f5;
  transform: scale(0.98);
}

.menu-item:hover {
  background-color: #f9f9f9;
  transform: translateX(5rpx);
}

.menu-item:hover::before {
  opacity: 1;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
  transition: all 0.3s ease-in-out;
}

.menu-item:hover .menu-icon {
  transform: scale(1.1);
}

/* 图标颜色 */
.activity-icon {
  color: #FF6B8B; /* 活动红 */
}

.post-icon {
  color: #48BFE3; /* 帖子蓝 */
}

.favorite-icon {
  color: #FDE047; /* 收藏黄 */
}

.history-icon {
  color: #6BFFB8; /* 历史绿 */
}

.settings-icon {
  color: #9333EA; /* 设置紫 */
}

.privacy-icon {
  color: #FB923C; /* 隐私橙 */
}

.help-icon {
  color: #34D399; /* 帮助绿 */
}

.about-icon {
  color: #60A5FA; /* 关于蓝 */
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
}

.menu-arrow {
  font-size: 24rpx;
  color: #CCCCCC;
  transition: all 0.3s ease-in-out;
}

.menu-item:hover .menu-arrow {
  color: #999999;
  transform: translateX(5rpx);
}

/* 退出登录按钮 */
.logout-btn {
  margin: 40rpx 20rpx;
  padding: 25rpx;
  background-color: white;
  border-radius: 16rpx;
  text-align: center;
  font-size: 28rpx;
  color: #ff4d4f;
  font-weight: bold;
  border: 2rpx solid #ff4d4f;
  box-shadow: 0 4rpx 12rpx rgba(255,77,79,0.1);
  transition: all 0.2s ease-in-out;
}

.logout-btn:active {
  background-color: #fff1f0;
  transform: scale(0.98);
}

.logout-btn:hover {
  background-color: #fff1f0;
  transform: translateY(-2rpx);
  box-shadow: 0 6rpx 16rpx rgba(255,77,79,0.15);
}

/* 响应式调整 */
@media (max-width: 375px) {
  .user-info {
    padding: 0 20rpx;
  }
  
  .avatar {
    width: 100rpx;
    height: 100rpx;
  }
  
  .username {
    font-size: 28rpx;
  }
  
  .user-desc {
    font-size: 20rpx;
  }
  
  .edit-btn {
    padding: 8rpx 20rpx;
    font-size: 20rpx;
  }
  
  .stats {
    margin: 15rpx 15rpx;
    padding: 20rpx 0;
  }
  
  .stat-value {
    font-size: 28rpx;
  }
  
  .stat-label {
    font-size: 20rpx;
  }
  
  .menu-section {
    margin: 15rpx 15rpx;
  }
  
  .menu-title {
    font-size: 24rpx;
    padding: 15rpx 20rpx;
  }
  
  .menu-item {
    padding: 20rpx 20rpx;
  }
  
  .menu-text {
    font-size: 24rpx;
  }
  
  .logout-btn {
    margin: 30rpx 15rpx;
    padding: 20rpx;
    font-size: 24rpx;
  }
}