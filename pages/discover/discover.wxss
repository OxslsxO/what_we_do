/* 全局样式 */
.container {
  padding: 0;
  background-color: #FFFAF5; /* 浅米色背景 */
  min-height: 100vh;
  color: #333333; /* 深灰色文字 */
}

/* 顶部导航 */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background-color: #ffffff;
  border-bottom: 1rpx solid #e5e5e5;
  position: sticky;
  top: 0;
  z-index: 10;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
}

.header-actions {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.filter-btn {
  padding: 8rpx 16rpx;
  border: 2rpx solid #FF6B8B; /* 主色边框 */
  border-radius: 20rpx;
  background-color: rgba(255, 107, 139, 0.1);
  transition: all 0.3s ease;
}

.filter-btn:hover {
  background-color: rgba(255, 107, 139, 0.2);
  transform: translateY(-2rpx);
}

.filter-btn:active {
  transform: scale(0.98);
}

.filter-icon {
  font-size: 28rpx;
  color: #FF6B8B; /* 主色文字 */
  font-weight: 500;
}

.post-btn {
  width: 48rpx;
  height: 48rpx;
  background-color: #FF6B8B; /* 主色按钮 */
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 139, 0.3);
  transition: all 0.3s ease;
}

.post-btn:hover {
  transform: scale(1.05);
  box-shadow: 0 6rpx 16rpx rgba(255, 107, 139, 0.4);
}

.post-btn:active {
  transform: scale(0.98);
}

.post-btn-icon {
  font-size: 32rpx;
  color: #ffffff;
  font-weight: bold;
}

/* 筛选弹窗 */
.filter-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 99;
}

.filter-modal {
  position: fixed;
  top: 0;
  right: 0;
  width: 80%;
  height: 100vh;
  z-index: 100;
  backdrop-filter: blur(10rpx); /* 玻璃拟态效果 */
  background-color: rgba(255, 255, 255, 0.9);
  box-shadow: -4rpx 0 20rpx rgba(0, 0, 0, 0.1);
}

.filter-modal-content {
  height: 100%;
  display: flex;
  flex-direction: column;
}

.filter-modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.1);
}

.filter-modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.filter-modal-close {
  font-size: 36rpx;
  color: #999999;
  transition: all 0.3s ease;
}

.filter-modal-close:hover {
  color: #FF6B8B;
  transform: scale(1.1);
}

.filter-modal-close:active {
  transform: scale(0.9);
}

.filter-section {
  padding: 20rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.1);
  flex: 1;
  overflow-y: auto;
}

.filter-section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 15rpx;
}

.filter-tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.filter-tag-item {
  padding: 10rpx 20rpx;
  background-color: #f0f0f0;
  border-radius: 20rpx;
  white-space: nowrap;
  transition: all 0.3s ease;
  border: 2rpx solid transparent;
}

.filter-tag-item.active {
  background-color: rgba(255, 107, 139, 0.1);
  border: 2rpx solid #FF6B8B;
  color: #FF6B8B;
  transform: translateY(-2rpx);
}

.filter-tag-item:active {
  transform: scale(0.95);
}

.filter-tag-text {
  font-size: 24rpx;
}

.filter-play-type-list {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 15rpx;
}

.filter-play-type-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 15rpx;
  background-color: #f0f0f0;
  border-radius: 15rpx;
  transition: all 0.3s ease;
  border: 2rpx solid transparent;
}

.filter-play-type-item.active {
  background-color: rgba(72, 191, 227, 0.1);
  border: 2rpx solid #48BFE3;
  transform: translateY(-2rpx);
}

.filter-play-type-item:active {
  transform: scale(0.95);
}

.filter-play-type-icon {
  font-size: 32rpx;
}

.filter-play-type-text {
  font-size: 24rpx;
  color: #333333;
}

.filter-modal-footer {
  display: flex;
  justify-content: space-between;
  padding: 20rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.1);
  background-color: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(10rpx);
}

.filter-reset {
  flex: 1;
  text-align: center;
  padding: 15rpx;
  border: 2rpx solid #e5e5e5;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #666666;
  margin-right: 10rpx;
  transition: all 0.3s ease;
}

.filter-reset:hover {
  border-color: #999999;
  transform: translateY(-2rpx);
}

.filter-reset:active {
  transform: scale(0.98);
}

.filter-confirm {
  flex: 1;
  text-align: center;
  padding: 15rpx;
  background-color: #FF6B8B;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #ffffff;
  font-weight: bold;
  margin-left: 10rpx;
  transition: all 0.3s ease;
  box-shadow: 0 4rpx 8rpx rgba(255, 107, 139, 0.3);
}

.filter-confirm:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 6rpx 12rpx rgba(255, 107, 139, 0.4);
}

.filter-confirm:active {
  transform: scale(0.98);
}

/* 帖子列表 */
.post-list {
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.post-item {
  background-color: #ffffff;
  border-radius: 18rpx;
  padding: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s ease;
  transform: translateY(0);
}

.post-item:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.08);
}

.post-header {
  display: flex;
  align-items: center;
  gap: 15rpx;
  margin-bottom: 15rpx;
}

.avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  border: 2rpx solid #FF6B8B;
}

.author-info {
  flex: 1;
}

.author-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 5rpx;
}

.post-time {
  font-size: 24rpx;
  color: #999999;
}

.post-content {
  margin-bottom: 15rpx;
}

.content-text {
  font-size: 32rpx;
  color: #333333;
  line-height: 48rpx;
  margin-bottom: 15rpx;
}

.post-images {
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
  margin-top: 10rpx;
}

/* 正方形容器 - 宽高相等，控制图片布局 */
.img-square-container {
  width: 200rpx;
  height: 200rpx;
  position: relative;
  overflow: hidden;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #f5f5f5, #e0e0e0);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

/* 图片样式 - 自适应填满容器，保持比例 */
.post-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  opacity: 0;
  transform: scale(1.1);
  transition: all 0.3s ease;
}

.post-image.loaded {
  opacity: 1;
  transform: scale(1);
}

.no-image-placeholder {
  width: 100%;
  height: 200rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #f5f5f5, #e0e0e0);
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  margin-top: 10rpx;
}

.no-image-icon {
  font-size: 48rpx;
  margin-bottom: 10rpx;
  color: #999999;
}

.no-image-text {
  font-size: 24rpx;
  color: #999999;
}

.post-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 15rpx;
}

.tag {
  padding: 5rpx 15rpx;
  background-color: rgba(72, 191, 227, 0.1);
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #48BFE3;
  border: 1rpx solid rgba(72, 191, 227, 0.3);
}

.post-actions {
  display: flex;
  justify-content: space-around;
  padding-top: 15rpx;
  border-top: 1rpx solid #e5e5e5;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 5rpx;
  transition: all 0.3s ease;
  padding: 10rpx;
  border-radius: 10rpx;
}

.action-item:hover {
  background-color: rgba(0, 0, 0, 0.05);
  transform: scale(1.05);
}

.action-item:active {
  transform: scale(0.98);
}

.action-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #f5f5f5;
  transition: all 0.3s ease;
}

.action-btn.liked {
  background-color: rgba(255, 107, 139, 0.1);
}

.action-btn.collected {
  background-color: rgba(253, 224, 71, 0.1);
}

.action-icon {
  font-size: 36rpx;
  transition: all 0.3s ease;
}

.action-icon.liked {
  color: #FF6B8B;
  animation: pulse 0.3s ease;
}

.action-icon.collected {
  color: #FDE047;
  animation: pulse 0.3s ease;
}

.action-text {
  font-size: 24rpx;
  color: #666666;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 30rpx 0;
}

.load-more-content {
  display: inline-block;
  padding: 15rpx 40rpx;
  background-color: #ffffff;
  border-radius: 25rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease;
  animation: breathe 2s infinite ease-in-out;
}

.load-more-content:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}

.load-more-content:active {
  transform: scale(0.98);
}

.load-more-text {
  font-size: 28rpx;
  color: #666666;
  font-weight: 500;
}

.loading-spinner {
  display: flex;
  justify-content: center;
  align-items: center;
}

.loading-icon {
  font-size: 32rpx;
  color: #FF6B8B;
  animation: spin 1s infinite linear;
}

.no-more {
  text-align: center;
  padding: 30rpx 0;
  font-size: 28rpx;
  color: #999999;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
  gap: 30rpx;
}

.empty-icon {
  font-size: 120rpx;
  animation: bounce 2s infinite ease-in-out;
}

.empty-text {
  font-size: 32rpx;
  color: #999999;
  text-align: center;
  line-height: 48rpx;
}

.empty-btn {
  padding: 15rpx 40rpx;
  background-color: #FF6B8B;
  border-radius: 25rpx;
  transition: all 0.3s ease;
  box-shadow: 0 4rpx 8rpx rgba(255, 107, 139, 0.3);
}

.empty-btn:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 6rpx 12rpx rgba(255, 107, 139, 0.4);
}

.empty-btn:active {
  transform: scale(0.98);
}

.empty-btn-text {
  font-size: 28rpx;
  color: #ffffff;
  font-weight: bold;
}

/* 动画效果 */
@keyframes pulse {
  0% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.2);
  }
  100% {
    transform: scale(1);
  }
}

@keyframes breathe {
  0% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.05);
  }
  100% {
    transform: scale(1);
  }
}

@keyframes spin {
  from {
    transform: rotate(0deg);
  }
  to {
    transform: rotate(360deg);
  }
}

@keyframes bounce {
  0%, 20%, 50%, 80%, 100% {
    transform: translateY(0);
  }
  40% {
    transform: translateY(-20rpx);
  }
  60% {
    transform: translateY(-10rpx);
  }
}

/* 深色模式适配 */
@media (prefers-color-scheme: dark) {
  .container {
    background-color: #1a1a1a;
    color: #e0e0e0;
  }
  
  .header {
    background-color: #2a2a2a;
    border-bottom: 1rpx solid #3a3a3a;
  }
  
  .title {
    color: #e0e0e0;
  }
  
  .filter-btn {
    border-color: #6BFFB8;
    background-color: rgba(107, 255, 184, 0.1);
  }
  
  .filter-icon {
    color: #6BFFB8;
  }
  
  .post-btn {
    background-color: #6BFFB8;
    box-shadow: 0 4rpx 12rpx rgba(107, 255, 184, 0.3);
  }
  
  .post-btn-icon {
    color: #1a1a1a;
  }
  
  .filter-modal {
    background-color: rgba(42, 42, 42, 0.9);
  }
  
  .filter-modal-header {
    border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
  }
  
  .filter-modal-title {
    color: #e0e0e0;
  }
  
  .filter-section {
    border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
  }
  
  .filter-section-title {
    color: #e0e0e0;
  }
  
  .filter-tag-item {
    background-color: #3a3a3a;
  }
  
  .filter-tag-item.active {
    background-color: rgba(107, 255, 184, 0.1);
    border-color: #6BFFB8;
    color: #6BFFB8;
  }
  
  .filter-play-type-item {
    background-color: #3a3a3a;
  }
  
  .filter-play-type-item.active {
    background-color: rgba(72, 191, 227, 0.1);
    border-color: #48BFE3;
  }
  
  .filter-play-type-text {
    color: #e0e0e0;
  }
  
  .filter-modal-footer {
    background-color: rgba(42, 42, 42, 0.9);
    border-top: 1rpx solid rgba(255, 255, 255, 0.1);
  }
  
  .filter-reset {
    border-color: #3a3a3a;
    color: #e0e0e0;
  }
  
  .filter-reset:hover {
    border-color: #5a5a5a;
  }
  
  .filter-confirm {
    background-color: #6BFFB8;
    color: #1a1a1a;
    box-shadow: 0 4rpx 8rpx rgba(107, 255, 184, 0.3);
  }
  
  .post-item {
    background-color: #2a2a2a;
    box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.2);
  }
  
  .author-name {
    color: #e0e0e0;
  }
  
  .content-text {
    color: #e0e0e0;
  }
  
  .img-square-container {
    background: linear-gradient(135deg, #3a3a3a, #2a2a2a);
    box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
  }
  
  .no-image-placeholder {
    background: linear-gradient(135deg, #3a3a3a, #2a2a2a);
    box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
  }
  
  .tag {
    background-color: rgba(72, 191, 227, 0.1);
    color: #48BFE3;
    border: 1rpx solid rgba(72, 191, 227, 0.3);
  }
  
  .action-item:hover {
    background-color: rgba(255, 255, 255, 0.05);
  }
  
  .action-btn {
    background-color: #3a3a3a;
  }
  
  .action-btn.liked {
    background-color: rgba(107, 255, 184, 0.1);
  }
  
  .action-btn.collected {
    background-color: rgba(253, 224, 71, 0.1);
  }
  
  .action-icon.liked {
    color: #6BFFB8;
  }
  
  .action-icon.collected {
    color: #FDE047;
  }
  
  .action-text {
    color: #999999;
  }
  
  .load-more-content {
    background-color: #2a2a2a;
    box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
  }
  
  .load-more-text {
    color: #e0e0e0;
  }
  
  .loading-icon {
    color: #6BFFB8;
  }
  
  .no-more {
    color: #666666;
  }
  
  .empty-text {
    color: #666666;
  }
  
  .empty-btn {
    background-color: #6BFFB8;
    color: #1a1a1a;
    box-shadow: 0 4rpx 8rpx rgba(107, 255, 184, 0.3);
  }
  
  .empty-btn-text {
    color: #1a1a1a;
  }
}