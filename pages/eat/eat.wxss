/* pages/eat/eat.wxss */
/* 全局样式 */
.container {
  width: 100%;
  min-height: 100vh;
  /* 浅粉色渐变底色 */
  background: linear-gradient(135deg, #FFF5F8 0%, #FFE6F2 100%);
  padding: 40rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 30rpx;
}

/* 标题样式 */
.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #333333;
  text-align: center;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.1);
  letter-spacing: 2rpx;
}

/* 毛玻璃卡片 */
.glass-card {
  width: 90%;
  max-width: 600rpx;
  background: rgba(255, 255, 255, 0.8);
  backdrop-filter: blur(10rpx);
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.05);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 30rpx;
}

/* 初始状态 */
.initial-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  padding: 40rpx 0;
}

.initial-icon {
  font-size: 120rpx;
  animation: pulse 2s infinite ease-in-out;
}

.initial-text {
  font-size: 28rpx;
  color: #666666;
  text-align: center;
}

/* 食物展示区 */
.food-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 0;
}

.food-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
}

.food-image image {
  width: 100%;
  height: 100%;
}

.food-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  text-align: center;
}

/* 按钮样式 */
.generate-btn {
  width: 100%;
  background: linear-gradient(135deg, #FF6B8B, #FF8FA3);
  border-radius: 20rpx;
  padding: 24rpx 0;
  border: none;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  color: white;
  font-size: 28rpx;
  font-weight: bold;
  box-shadow: 0 6rpx 16rpx rgba(255,107,139,0.3);
  transition: all 0.2s ease-in-out;
}

.generate-btn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(255,107,139,0.2);
}

.btn-icon {
  font-size: 32rpx;
}

.btn-text {
  font-size: 28rpx;
}

/* 功能按钮区 */
.action-buttons {
  width: 90%;
  max-width: 600rpx;
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  min-width: 180rpx;
  background: white;
  border-radius: 20rpx;
  padding: 24rpx 0;
  border: none;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
  transition: all 0.2s ease-in-out;
}

.action-btn:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.sky-btn {
  background: linear-gradient(135deg, #87CEEB, #B0E0E6);
  color: white;
}

.recipe-btn {
  background: linear-gradient(135deg, #98FB98, #90EE90);
  color: white;
}

.meituan-btn {
  background: linear-gradient(135deg, #FFD700, #FFA500);
  color: white;
}

/* 菜谱展示区 */
.recipe-container {
  width: 90%;
  max-width: 600rpx;
  background: rgba(255, 255, 255, 0.8);
  backdrop-filter: blur(10rpx);
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.05);
  margin-top: 20rpx;
}

.recipe-title {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
  padding-bottom: 15rpx;
  border-bottom: 1rpx solid #EEEEEE;
}

.recipe-icon {
  font-size: 32rpx;
}

.recipe-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
}

.recipe-content {
  font-size: 24rpx;
  line-height: 1.6;
  color: #666666;
  white-space: pre-wrap;
}

/* 弹窗样式 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 85%;
  max-width: 500rpx;
  background: white;
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 12rpx 32rpx rgba(0,0,0,0.15);
}

.modal-title {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #EEEEEE;
}

.modal-icon {
  font-size: 32rpx;
}

.modal-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

/* 表单样式 */
.form-item {
  margin-bottom: 25rpx;
}

.form-label {
  font-size: 24rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 10rpx;
}

.form-input {
  width: 100%;
  padding: 16rpx 20rpx;
  border: 1rpx solid #EEEEEE;
  border-radius: 12rpx;
  font-size: 24rpx;
  background: #F9F9F9;
}

.form-textarea {
  width: 100%;
  height: 120rpx;
  padding: 16rpx 20rpx;
  border: 1rpx solid #EEEEEE;
  border-radius: 12rpx;
  font-size: 24rpx;
  background: #F9F9F9;
  resize: none;
}

.happiness-slider {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 20rpx;
}

.happiness-slider input {
  flex: 1;
}

.happiness-value {
  font-size: 24rpx;
  color: #666666;
  min-width: 80rpx;
}

/* 弹窗按钮 */
.modal-buttons {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 30rpx;
}

.modal-btn {
  flex: 1;
  padding: 20rpx 0;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: 500;
  border: none;
  transition: all 0.2s ease-in-out;
}

.cancel-btn {
  background: #F0F0F0;
  color: #666666;
}

.submit-btn {
  background: linear-gradient(135deg, #FF6B8B, #FF8FA3);
  color: white;
}

.modal-btn:active {
  transform: scale(0.98);
}

/* 动画效果 */
@keyframes pulse {
  0%, 100% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.05);
  }
}

.publish-btn {
  background: linear-gradient(135deg, #9370DB, #BA55D3);
  color: white;
  box-shadow: 0 6rpx 16rpx rgba(147,112,219,0.3);
}

.publish-btn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(147,112,219,0.2);
}

/* 响应式调整 */
@media (max-width: 375px) {
  .glass-card {
    width: 95%;
    padding: 30rpx;
  }
  
  .action-buttons {
    width: 95%;
  }
  
  .action-btn {
    min-width: 160rpx;
  }
  
  .recipe-container {
    width: 95%;
    padding: 20rpx;
  }
  
  .modal-content {
    width: 90%;
  }
  
  .publish-section {
    width: 95%;
  }
}