.page {
  min-height: 100vh;
  background-color: #FFF8F2;
  padding: 40rpx;
}

.wallet-header {
  margin-bottom: 40rpx;
  text-align: center;
}

.wallet-title {
  font-size: 56rpx;
  font-weight: bold;
  color: #1A1A1A;
  margin-bottom: 12rpx;
}

.wallet-desc {
  font-size: 28rpx;
  color: #8C7B75;
}

.empty-state {
  text-align: center;
  padding: 120rpx 0;
  color: #999;
}

.coupon-list {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.coupon-card {
  background: white;
  border-radius: 24rpx;
  display: flex;
  overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.06);
  position: relative;
}

.coupon-card.used {
  opacity: 0.6;
  filter: grayscale(100%);
}

.coupon-left {
  width: 140rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  writing-mode: vertical-lr;
  color: white;
  font-weight: 900;
  font-size: 32rpx;
  letter-spacing: 4rpx;
}

.bg-ssr { background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%); text-shadow: 0 4rpx 12rpx rgba(255, 165, 0, 0.4); }
.bg-sr  { background: linear-gradient(135deg, #FF6B6B 0%, #FF4757 100%); }
.bg-r   { background: linear-gradient(135deg, #70A1FF 0%, #1E90FF 100%); }

.coupon-body {
  flex: 1;
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.coupon-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #1A1A1A;
  margin-bottom: 12rpx;
}

.coupon-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
  margin-bottom: 24rpx;
}

.coupon-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: auto;
}

.coupon-date {
  font-size: 24rpx;
  color: #CCC;
}

.use-btn {
  background: #1A1A1A;
  color: white;
  font-size: 26rpx;
  font-weight: bold;
  padding: 12rpx 32rpx;
  border-radius: 100rpx;
  margin: 0;
}

.use-btn.disabled {
  background: #f0f0f0;
  color: #999;
}
