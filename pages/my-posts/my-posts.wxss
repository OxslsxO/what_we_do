.container {
  min-height: 100vh;
  padding: 24rpx;
  background:
    radial-gradient(circle at top left, rgba(255, 233, 196, 0.86), transparent 24%),
    linear-gradient(180deg, #fff8ee 0%, #fffdf8 56%, #f8f2e8 100%);
  box-sizing: border-box;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
  padding: 10rpx 6rpx;
}

.back-btn,
.placeholder {
  width: 56rpx;
}

.back-btn {
  font-size: 40rpx;
  color: #8a6644;
}

.title {
  font-size: 34rpx;
  font-weight: 700;
  color: #5d4634;
}

.post-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.post-item {
  padding: 26rpx;
  border-radius: 30rpx;
  background: var(--card-bg-gradient);
  border: 1rpx solid rgba(228, 201, 165, 0.55);
  box-shadow: 0 14rpx 30rpx rgba(171, 141, 98, 0.1);
}

.post-type {
  display: inline-block;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(243, 221, 186, 0.55);
  color: #8e6841;
  font-size: 20rpx;
}

.post-title {
  margin-top: 14rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #5d4634;
}

.post-content {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #8a725b;
}

.post-images {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.img-square-container {
  width: 200rpx;
  height: 200rpx;
  position: relative;
  overflow: hidden;
  border-radius: 18rpx;
}

.post-image {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.post-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 16rpx;
}

.tag {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 248, 236, 0.92);
  border: 1rpx solid rgba(227, 199, 160, 0.6);
  font-size: 22rpx;
  color: #82674b;
}

.post-info {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 18rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid rgba(226, 208, 178, 0.56);
}

.post-time,
.post-meta {
  font-size: 22rpx;
  color: #9b7d5a;
}

.load-more,
.no-more {
  text-align: center;
  padding: 22rpx 0;
  font-size: 24rpx;
  color: #9b7d5a;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 120rpx;
}

.empty-text {
  margin-top: 22rpx;
  font-size: 28rpx;
  color: #8a725b;
}

.empty-btn {
  margin-top: 24rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #d5a369, #ecd198);
  color: #fffaf2;
  font-size: 28rpx;
  font-weight: 700;
  box-shadow: 0 14rpx 26rpx rgba(192, 141, 77, 0.22);
}
