.container {
  background-color: #f5f5f5;
  min-height: 100vh;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background-color: #ffffff;
  border-bottom: 1rpx solid #e5e5e5;
  position: sticky;
  top: 0;
  z-index: 10;
}

.back-btn {
  font-size: 36rpx;
  color: #333333;
  width: 40rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
}

.placeholder {
  width: 40rpx;
}

.post-list {
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.post-item {
  background-color: #ffffff;
  border-radius: 12rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.post-content {
  margin-bottom: 15rpx;
}

.content-text {
  font-size: 32rpx;
  color: #333333;
  line-height: 48rpx;
  margin-bottom: 15rpx;
}


.post-images {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 10rpx;
  position: relative;
  z-index: 1;
}

/* 关键：新增图片容器，限制图片范围（正方形） */
.img-square-container {
  width: 200rpx;       
  height: 200rpx;      
  position: relative; 
  overflow: hidden;    
  border-radius: 8rpx; 
}

/* 图片样式 - 仅在容器内铺满，不溢出 */
.post-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;   
  height: 100%;  
  object-fit: cover; /* 或 aspectFit 对应小程序mode，这里用object-fit适配CSS */
}

.post-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 15rpx;
}

.tag {
  padding: 5rpx 15rpx;
  background-color: #f0f0f0;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #666666;
}

.post-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
  padding-bottom: 15rpx;
  border-bottom: 1rpx solid #e5e5e5;
}

.post-time {
  font-size: 24rpx;
  color: #999999;
}

.post-type {
  font-size: 24rpx;
  color: #1890ff;
  padding: 2rpx 12rpx;
  background-color: #e6f7ff;
  border-radius: 12rpx;
}

.post-actions {
  display: flex;
  justify-content: space-around;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 5rpx;
}

.action-icon {
  font-size: 36rpx;
}

.action-text {
  font-size: 24rpx;
  color: #666666;
}

.load-more, .no-more {
  text-align: center;
  padding: 30rpx 0;
  font-size: 28rpx;
  color: #999999;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
  gap: 30rpx;
}

.empty-icon {
  font-size: 120rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #999999;
  text-align: center;
}

.empty-btn {
  padding: 15rpx 40rpx;
  background-color: #1890ff;
  border-radius: 25rpx;
}

.empty-btn-text {
  font-size: 28rpx;
  color: #ffffff;
  font-weight: bold;
}