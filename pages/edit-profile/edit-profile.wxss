/* pages/edit-profile/edit-profile.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}

.title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.save-btn {
  background: #e67e22;
  color: #fff;
  border: none;
  border-radius: 8rpx;
  padding: 10rpx 20rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.form {
  background: #fff;
  margin-top: 20rpx;
  padding: 0 30rpx;
}

.form-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  position: relative;
}

.avatar-uploader {
  display: flex;
  align-items: center;
  gap: 30rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  object-fit: cover;
  border: 1rpx solid #e0e0e0;
}

.avatar-upload-btn {
  padding: 12rpx 24rpx;
  background: #f0f0f0;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #666;
  transition: all 0.3s ease;
}

.avatar-upload-btn:hover {
  background: #e0e0e0;
}

.label {
  display: block;
  font-size: 24rpx;
  color: #666;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.input {
  width: 100%;
  font-size: 28rpx;
  color: #333;
  padding: 0;
  border: none;
  background: transparent;
}

.input::placeholder {
  color: #c9c0b3;
}

.textarea {
  width: 100%;
  font-size: 28rpx;
  color: #333;
  padding: 0;
  border: none;
  background: transparent;
  min-height: 120rpx;
  resize: none;
}

.placeholder {
  color: #c9c0b3;
}

.count {
  position: absolute;
  bottom: 16rpx;
  right: 0;
  font-size: 20rpx;
  color: #999;
}

.gender-selector {
  display: flex;
  gap: 20rpx;
}

.gender-option {
  flex: 1;
  padding: 12rpx 0;
  border: 1rpx solid #e0e0e0;
  border-radius: 8rpx;
  text-align: center;
  font-size: 24rpx;
  color: #666;
  transition: all 0.3s ease;
}

.gender-option.active {
  border-color: #e67e22;
  color: #e67e22;
  background: #f5e8d3;
}

.gender-display {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.gender-display text {
  font-size: 28rpx;
  color: #333;
}

.hint {
  font-size: 20rpx;
  color: #999;
}

.date-picker {
  padding: 12rpx 0;
}

.picker-text {
  font-size: 28rpx;
  color: #333;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.picker-text::after {
  content: '▼';
  font-size: 20rpx;
  color: #999;
  margin-left: 16rpx;
}

.error-message {
  font-size: 20rpx;
  color: #e74c3c;
  margin-top: 8rpx;
}

.toast {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: rgba(0, 0, 0, 0.7);
  color: #fff;
  padding: 20rpx 30rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  z-index: 9999;
}
