/* 全局样式 */
.container {
  width: 100%;
  min-height: 100vh;
  /* 浅粉色渐变底色 */
  background: linear-gradient(135deg, #FFF5F8 0%, #FFE6F2 100%);
  padding: 40rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 标题样式 */
.title {
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 60rpx;
  color: #333333;
  text-align: center;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.1);
  letter-spacing: 2rpx;
}

/* 主要功能（大按钮） */
.main-options {
  width: 90%;
  max-width: 700rpx;
  margin: 0 auto 60rpx;
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  gap: 20rpx;
}

.main-option {
  flex: 1;
  background-color: white;
  border-radius: 20rpx;
  padding: 50rpx 0;
  box-shadow: 0 8rpx 24rpx rgba(255,0,0,0.05);
  text-align: center;
  transition: all 0.2s ease-in-out;
  position: relative;
  overflow: hidden;
}

.main-option::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, #FF6B8B, #FF8FA3);
}

.main-option:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(255,0,0,0.05);
}

.main-option:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 12rpx 32rpx rgba(255,0,0,0.08);
}

.main-option-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  position: relative;
  display: inline-block;
}

/* 爱心图标渐变效果 */
.love-icon {
  background: linear-gradient(135deg, #FF6B8B, #FF8FA3);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  animation: pulse 2s infinite ease-in-out;
}

/* 星星图标渐变效果 */
.star-icon {
  background: linear-gradient(135deg, #FDE047, #48BFE3);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  animation: pulse 2s infinite ease-in-out 0.5s;
}

.main-option-text {
  font-size: 28rpx;
  color: #333333;
  font-weight: bold;
  letter-spacing: 1rpx;
}

/* 新功能（小按钮） */
.new-options {
  width: 90%;
  max-width: 700rpx;
  margin: 0 auto;
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  gap: 20rpx;
}

.new-option {
  width: 18%;
  aspect-ratio: 1;
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
  transition: all 0.2s ease-in-out;
  position: relative;
  overflow: hidden;
  background-color: white;
}

.new-option::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255,255,255,0.3);
  opacity: 0;
  transition: opacity 0.2s ease-in-out;
}

.new-option:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

.new-option:hover {
  transform: scale(1.02);
  box-shadow: 0 6rpx 16rpx rgba(0,0,0,0.08);
}

.new-option:hover::before {
  opacity: 1;
}

/* 不同颜色背景 */
.blue-bg {
  background-color: #E6F7FF !important;
}

.red-bg {
  background-color: #FFF0F0 !important;
}

.yellow-bg {
  background-color: #FFF9E6 !important;
}

.pink-bg {
  background-color: #FFE6F2 !important;
}

.green-bg {
  background-color: #E6FFE6 !important;
}

.new-option-icon {
  font-size: 50rpx;
  margin-bottom: 12rpx;
}

.new-option-text {
  font-size: 24rpx;
  color: #333333;
  font-weight: 500;
  line-height: 1.3;
  text-align: center;
}

/* 动画效果 */
@keyframes pulse {
  0%, 100% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.05);
  }
}

/* 响应式调整 */
@media (max-width: 375px) {
  .main-options {
    width: 90%;
  }
  
  .main-option {
    padding: 60rpx 0;
  }
  
  .main-option-icon {
    font-size: 80rpx;
  }
  
  .new-option {
    width: 17%;
  }
  
  .new-option-icon {
    font-size: 40rpx;
  }
  
  .new-option-text {
    font-size: 20rpx;
  }
}