.page {
  min-height: 100vh;
  padding: 24rpx 24rpx 48rpx;
  background:
    radial-gradient(circle at top left, rgba(255, 233, 196, 0.86), transparent 24%),
    linear-gradient(180deg, #fff8ee 0%, #fffdf8 56%, #f8f2e8 100%);
  box-sizing: border-box;
}

.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
  padding: 10rpx 6rpx;
}

.nav-back,
.nav-placeholder {
  width: 56rpx;
}

.nav-back {
  font-size: 40rpx;
  color: #8a6644;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #5d4634;
}

.info-card,
.editor-card {
  margin-top: 18rpx;
  padding: 28rpx;
  border-radius: 30rpx;
  background: rgba(255, 252, 247, 0.92);
  border: 1rpx solid rgba(228, 201, 165, 0.55);
  box-shadow: 0 14rpx 30rpx rgba(171, 141, 98, 0.1);
}

.meta-row + .meta-row {
  margin-top: 22rpx;
}

.meta-label,
.field-label {
  margin-bottom: 12rpx;
  font-size: 24rpx;
  color: #7a5b3d;
}

.meta-value {
  font-size: 30rpx;
  font-weight: 700;
  color: #5c4634;
}

.template-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.template-chip {
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(255, 251, 245, 0.95);
  border: 1rpx solid rgba(227, 199, 160, 0.76);
  font-size: 24rpx;
  color: #7c6247;
}

.template-chip-active {
  background: linear-gradient(135deg, #f3d4a3, #f4e4bd);
  color: #694b2d;
  border-color: rgba(202, 157, 89, 0.82);
}

.field-input,
.field-textarea {
  width: 100%;
  box-sizing: border-box;
  padding: 24rpx;
  border-radius: 22rpx;
  border: 1rpx solid rgba(227, 199, 160, 0.76);
  background: rgba(255, 255, 255, 0.78);
  font-size: 26rpx;
  color: #5c4632;
}

.summary-textarea {
  min-height: 160rpx;
}

.content-textarea {
  min-height: 340rpx;
}

.field-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.no-margin {
  margin-bottom: 0;
}

.field-tip {
  font-size: 22rpx;
  color: #9a7b59;
}

.media-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.media-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 22rpx;
  overflow: hidden;
  background: rgba(255, 248, 236, 0.92);
}

.media-item image,
.media-item video {
  width: 100%;
  height: 100%;
}

.delete-badge {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 999rpx;
  background: rgba(89, 61, 30, 0.6);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.add-media {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 1rpx dashed rgba(210, 170, 116, 0.82);
}

.add-icon {
  font-size: 42rpx;
  color: #956f42;
}

.add-text {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #956f42;
}

.footer {
  margin-top: 30rpx;
}

.publish-button {
  border-radius: 999rpx;
  background: linear-gradient(135deg, #d5a369, #ecd198);
  color: #fffaf2;
  font-size: 28rpx;
  font-weight: 700;
  box-shadow: 0 14rpx 26rpx rgba(192, 141, 77, 0.22);
}
