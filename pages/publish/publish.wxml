<!--pages/publish/publish.wxml-->
<view class="container">
  <!-- 顶部导航栏 -->
  <view class="nav-bar">
    <view class="nav-left" bindtap="goBack">
      <text class="nav-back">←</text>
    </view>
    <view class="nav-center">发布文章</view>
    <view class="nav-right" bindtap="publish">
      <text class="nav-publish">发布</text>
    </view>
  </view>
  
  <!-- 模块信息 -->
  <view class="module-info">
    <text class="module-label">模块：</text>
    <text class="module-value">{{module}}</text>
  </view>
  
  <!-- 食物信息 -->
  <view class="food-info">
    <text class="food-label">食物：</text>
    <text class="food-value">{{food}}</text>
  </view>
  
  <!-- 标题输入 -->
  <view class="input-section">
    <input 
      class="title-input" 
      placeholder="请输入文章标题" 
      value="{{title}}" 
      bindinput="updateTitle"
      maxlength="50"
    />
  </view>
  
  <!-- 内容输入 -->
  <view class="input-section">
    <textarea 
      class="content-input" 
      placeholder="请输入文章内容" 
      value="{{content}}" 
      bindinput="updateContent"
      maxlength="5000"
      auto-height
    />
  </view>
  
  <!-- 图片选择 -->
  <view class="image-section">
    <view class="image-title">图片</view>
    <view class="image-grid">
      <view class="image-item" wx:for="{{images}}" wx:key="index">
        <image src="{{item}}" mode="aspectFill"></image>
        <view class="image-delete" bindtap="deleteImage" data-index="{{index}}">
          <text>×</text>
        </view>
      </view>
      <view class="image-item add-image" bindtap="chooseImage" wx:if="{{images.length < 9}}">
        <text class="add-icon">+</text>
        <text class="add-text">添加图片</text>
      </view>
    </view>
  </view>
  
  <!-- 提示信息 -->
  <view class="tips">
    <text class="tips-text">提示：请确保内容真实有效，避免发布违规信息</text>
  </view>
</view>