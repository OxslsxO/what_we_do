.page {
  min-height: 100vh;
  padding: 28rpx 24rpx 48rpx;
  background:
    radial-gradient(circle at top left, rgba(255, 233, 196, 0.9), transparent 28%),
    radial-gradient(circle at top right, rgba(255, 246, 213, 0.88), transparent 26%),
    linear-gradient(180deg, #fff9ef 0%, #fffdf8 56%, #f8f2ea 100%);
  box-sizing: border-box;
}

.hero-card,
.memory-card,
.empty-card {
  border-radius: 32rpx;
  background: var(--card-bg-gradient);
  border: 1rpx solid rgba(230, 212, 183, 0.6);
  box-shadow: 0 18rpx 38rpx rgba(171, 141, 98, 0.1);
}

.hero-card,
.empty-card,
.memory-card {
  padding: 28rpx;
}

.hero-kicker,
.memory-module,
.memory-time {
  font-size: 20rpx;
  color: #a17b52;
  letter-spacing: 2rpx;
}

.hero-title {
  margin-top: 12rpx;
  font-size: 54rpx;
  font-weight: 700;
  color: #5d4634;
}

.hero-copy,
.empty-copy,
.memory-summary {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.72;
  color: #8a725b;
}

.hero-row,
.memory-head,
.memory-meta,
.empty-actions {
  display: flex;
  align-items: center;
}

.hero-row {
  gap: 12rpx;
  margin-top: 20rpx;
  flex-wrap: wrap;
}

.hero-pill,
.hero-link,
.filter-chip,
.memory-tag {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.hero-pill,
.memory-tag {
  background: rgba(244, 217, 174, 0.3);
  color: #8b6a46;
}

.hero-link {
  color: #8b7758;
  background: rgba(255, 253, 246, 0.7);
}

.filter-scroll {
  margin-top: 24rpx;
  white-space: nowrap;
}

.filter-row {
  display: inline-flex;
  gap: 12rpx;
  padding-right: 12rpx;
}

.filter-chip {
  background: rgba(255, 252, 247, 0.9);
  border: 1rpx solid rgba(227, 200, 165, 0.78);
  color: #7b6147;
}

.filter-chip-active {
  background: linear-gradient(135deg, #f5d7a7, #f2e6c2);
  color: #674a2e;
  border-color: rgba(201, 156, 91, 0.8);
}

.empty-card {
  margin-top: 24rpx;
}

.empty-title,
.memory-title {
  margin-top: 12rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #5e4735;
}

.empty-actions {
  gap: 14rpx;
  margin-top: 22rpx;
}

.memory-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 24rpx;
}

.memory-head {
  justify-content: space-between;
  gap: 16rpx;
}

.memory-meta {
  gap: 12rpx;
  flex-wrap: wrap;
}

.memory-participants {
  margin-top: 14rpx;
  font-size: 22rpx;
  color: #9b7f5e;
}

.memory-cover {
  width: 100%;
  height: 440rpx;
  margin-top: 20rpx;
  border-radius: 24rpx;
  background: rgba(245, 238, 227, 0.9);
}

.warm-button,
.ghost-button {
  flex: 1;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 600;
}

.warm-button {
  background: linear-gradient(135deg, #d4a26a, #ecd097);
  color: #fffaf2;
  box-shadow: 0 12rpx 24rpx rgba(192, 141, 78, 0.22);
}

.ghost-button {
  background: rgba(255, 252, 246, 0.9);
  color: #86684a;
  border: 1rpx solid rgba(221, 192, 149, 0.72);
}

.load-more {
  margin-top: 18rpx;
  text-align: center;
  color: #8f7b64;
  font-size: 24rpx;
}
