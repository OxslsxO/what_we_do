<!--pages/forgot-password/forgot-password.wxml-->
<view class="container">
  <view class="forgot-card">
    <view class="forgot-header">
      <text class="forgot-title">ж‰ңе›һеҮ†з Ѓ</text>
      <text class="forgot-subtitle">иҮ·йЂљиү‡ж‰‹жњғеЏ·йҒЊиҮЃй‡ҚзҢ®еҮ†з Ѓ</text>
    </view>
    
    <!-- еҮ†з Ѓж‰ңе›һиҰЁеҚ• -->
    <view class="forgot-form">
      <!-- ж‰‹жњғеЏ·иң“е…Ө -->
      <view class="form-item">
        <view class="input-wrapper">
          <text class="input-label">ж‰‹жњғеЏ·</text>
          <input 
            class="input" 
            placeholder="иҮ·иң“е…Өж‰‹жњғеЏ·" 
            placeholder-class="placeholder" 
            value="{{phone}}" 
            bindinput="handlePhoneInput" 
            maxlength="11"
            type="number"
          />
        </view>
        <text class="error-message" wx:if="errors.phone">{{errors.phone}}</text>
      </view>
      
      <!-- йҒЊиҮЃз Ѓиң“е…Ө -->
      <view class="form-item">
        <view class="input-wrapper code-input-wrapper">
          <text class="input-label">йҒЊиҮЃз Ѓ</text>
          <view class="code-input">
            <input 
              class="input" 
              placeholder="иҮ·иң“е…ӨйҒЊиҮЃз Ѓ" 
              placeholder-class="placeholder" 
              value="{{code}}" 
              bindinput="handleCodeInput" 
              maxlength="6"
              type="number"
            />
            <button 
              class="code-btn" 
              bindtap="sendCode" 
              disabled="{{countdown > 0}}"
            >
              {{countdown > 0 ? countdown + 's' : 'иҺ·еЏ–йҒЊиҮЃз Ѓ'}}
            </button>
          </view>
        </view>
        <text class="error-message" wx:if="errors.code">{{errors.code}}</text>
      </view>
      
      <!-- ж–°еҮ†з Ѓиң“е…Ө -->
      <view class="form-item">
        <view class="input-wrapper">
          <text class="input-label">ж–°еҮ†з Ѓ</text>
          <view class="password-input">
            <input 
              class="input" 
              placeholder="иҮ·и®ңзҢ®6-20дҢҚж–°еҮ†з Ѓ" 
              placeholder-class="placeholder" 
              value="{{newPassword}}" 
              bindinput="handleNewPasswordInput" 
              password="{{!showPassword}}"
              maxlength="20"
            />
            <text class="password-toggle" bindtap="togglePassword">
              {{showPassword ? 'рџ‘ЃпёЏ' : 'рџ‘ЃпёЏвЂҚрџ—ЁпёЏ'}}
            </text>
          </view>
        </view>
        <text class="error-message" wx:if="errors.newPassword">{{errors.newPassword}}</text>
        <text class="password-hint" wx:if="!errors.newPassword">еҮ†з Ѓй•үеғ¦6-20дҢҚпәЊе»ғи®®еЊ…еђ«е­—жҮҚе’Њж•°е­—</text>
      </view>
      
      <!-- зҰ®и®¤ж–°еҮ†з Ѓ -->
      <view class="form-item">
        <view class="input-wrapper">
          <text class="input-label">зҰ®и®¤ж–°еҮ†з Ѓ</text>
          <view class="password-input">
            <input 
              class="input" 
              placeholder="иҮ·е†Қж¬Ұиң“е…Өж–°еҮ†з Ѓ" 
              placeholder-class="placeholder" 
              value="{{confirmPassword}}" 
              bindinput="handleConfirmPasswordInput" 
              password="{{!showPassword}}"
              maxlength="20"
            />
          </view>
        </view>
        <text class="error-message" wx:if="errors.confirmPassword">{{errors.confirmPassword}}</text>
      </view>
      
      <!-- й‡ҚзҢ®еҮ†з ЃжЊ‰й’® -->
      <button 
        class="reset-btn" 
        bindtap="handleResetPassword" 
        loading="{{loading}}"
        disabled="{{loading}}"
      >
        й‡ҚзҢ®еҮ†з Ѓ
      </button>
    </view>
    
    <!-- з™»еҢ•й“ңжҺӨ -->
    <view class="login-link">
      <text>жѓіиµ·еҮ†з Ѓдғ†пәџ</text>
      <text class="login-btn" bindtap="goToLogin">з«‹еҚіз™»еҢ•</text>
    </view>
  </view>
  
  <!-- й”™иҮҮжЏђз¤ғ -->
  <view class="toast" wx:if="{{showToast}}">
    <text>{{toastMessage}}</text>
  </view>
</view>