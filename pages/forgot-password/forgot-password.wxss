/* pages/forgot-password/forgot-password.wxss */
.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  background: linear-gradient(135deg, #f5f5f5 0%, #e8f5e8 100%);
  padding: 40rpx;
}

.forgot-card {
  width: 100%;
  max-width: 500rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 48rpx;
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.1);
  backdrop-filter: blur(10rpx);
  border: 1rpx solid rgba(7, 193, 96, 0.1);
}

.forgot-header {
  text-align: center;
  margin-bottom: 48rpx;
}

.forgot-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

.forgot-subtitle {
  font-size: 24rpx;
  color: #666;
}

.forgot-form {
  margin-bottom: 40rpx;
}

.form-item {
  margin-bottom: 32rpx;
}

.input-wrapper {
  position: relative;
}

.input-label {
  display: block;
  font-size: 24rpx;
  color: #333;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.input {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid #f0f0f0;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
  background: #fafafa;
  transition: all 0.3s ease;
}

.input:focus {
  border-color: #07c160;
  background: #fff;
  box-shadow: 0 0 0 4rpx rgba(7, 193, 96, 0.1);
}

.placeholder {
  color: #999;
}

.password-input {
  position: relative;
}

.password-toggle {
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 32rpx;
  cursor: pointer;
}

.code-input-wrapper {
  margin-bottom: 8rpx;
}

.code-input {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.code-input .input {
  flex: 1;
}

.code-btn {
  width: 200rpx;
  height: 80rpx;
  border: 2rpx solid #07c160;
  border-radius: 12rpx;
  background: transparent;
  color: #07c160;
  font-size: 24rpx;
  line-height: 80rpx;
  padding: 0;
  transition: all 0.3s ease;
}

.code-btn:hover {
  background: #07c160;
  color: #fff;
}

.code-btn:disabled {
  border-color: #ccc;
  color: #ccc;
}

.error-message {
  font-size: 20rpx;
  color: #ff4d4f;
  margin-top: 8rpx;
  line-height: 1.4;
}

.password-hint {
  font-size: 20rpx;
  color: #999;
  margin-top: 8rpx;
  line-height: 1.4;
}

.reset-btn {
  width: 100%;
  height: 88rpx;
  background: #07c160;
  color: #fff;
  border: none;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: 500;
  margin-top: 16rpx;
  transition: all 0.3s ease;
}

.reset-btn:hover {
  background: #05a850;
  box-shadow: 0 4rpx 12rpx rgba(7, 193, 96, 0.3);
}

.login-link {
  text-align: center;
  font-size: 24rpx;
  color: #666;
}

.login-btn {
  color: #07c160;
  font-weight: 500;
  margin-left: 8rpx;
  cursor: pointer;
  transition: color 0.3s ease;
}

.login-btn:hover {
  color: #05a850;
}

.toast {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: rgba(0, 0, 0, 0.7);
  color: #fff;
  padding: 24rpx 48rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  z-index: 9999;
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translate(-50%, -50%) scale(0.8);
  }
  to {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1);
  }
}

/* 响应式设计 */
@media (max-width: 375px) {
  .forgot-card {
    padding: 32rpx;
  }
  
  .forgot-title {
    font-size: 36rpx;
  }
  
  .input {
    height: 72rpx;
  }
  
  .reset-btn {
    height: 80rpx;
  }
}

/* 加载状态 */
.reset-btn::after {
  border-color: rgba(255, 255, 255, 0.6);
  border-left-color: #fff;
}