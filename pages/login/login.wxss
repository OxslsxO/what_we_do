/* pages/login/login.wxss */
.container {
  min-height: 100vh;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40rpx;
  background: linear-gradient(135deg, #f9f3e9 0%, #f5e8d3 100%);
}

.login-card {
  width: 100%;
  max-width: 500rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 50rpx 40rpx;
  box-shadow: 0 12rpx 32rpx rgba(149, 157, 165, 0.15);
  backdrop-filter: blur(10rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.5);
}

.login-header {
  text-align: center;
  margin-bottom: 40rpx;
}

.login-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.login-subtitle {
  font-size: 24rpx;
  color: #666;
}

.login-tabs {
  display: flex;
  margin-bottom: 40rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #999;
  position: relative;
  transition: all 0.3s ease;
}

.tab-item.active {
  color: #e67e22;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: -1rpx;
  left: 20%;
  width: 60%;
  height: 3rpx;
  background-color: #e67e22;
  border-radius: 3rpx;
}

.login-form {
  margin-bottom: 40rpx;
}

.form-item {
  margin-bottom: 30rpx;
}

.input-wrapper {
  position: relative;
  background: #faf8f5;
  border-radius: 12rpx;
  padding: 24rpx;
  border: 1rpx solid #f0e6d8;
  transition: all 0.3s ease;
  display: flex;
  align-items: center;
}

.input-wrapper:focus-within {
  border-color: #e67e22;
  box-shadow: 0 0 0 3rpx rgba(230, 126, 34, 0.1);
}

.input-label {
  font-size: 24rpx;
  color: #666;
  font-weight: 500;
  margin-right: 16rpx;
  white-space: nowrap;
  width: 120rpx;
}

.input {
  width: 100%;
  font-size: 28rpx;
  color: #333;
  padding: 0;
  border: none;
  background: transparent;
}

.input::placeholder {
  color: #c9c0b3;
}

.password-input {
  display: flex;
  align-items: center;
}

.password-toggle {
  font-size: 32rpx;
  cursor: pointer;
  margin-left: 16rpx;
}

.code-input-wrapper {
  display: flex;
  align-items: center;
}

.code-input-field {
  flex: 1;
  min-width: 0;
  padding: 12rpx 0;
  margin-right: 12rpx;
}

.code-btn {
  /* 核心：设置按钮宽高（用rpx适配所有屏幕） */
  width: 140rpx !important;    /* 调整按钮宽度 */
  height: 68rpx !important;    /* 调整按钮高度 */
  
  /* 减小字体大小 */
  font-size: 28rpx !important; /* 调整字体大小 */
  
  /* 减小内边距（按钮内部空白） */
  padding: 0 !important;       /* 清空默认内边距，让按钮更紧凑 */
  margin: 0 !important;        /* 清空默认边距 */
  
  /* 可选：保持圆角协调（按需调整） */
  border-radius: 24rpx !important; /* 圆角值和高度一半一致，保持圆形边角 */
  
  /* 可选：行高和高度一致，文字垂直居中 */
  line-height: 70rpx !important;
  
  /* 可选：调整背景色/文字色（按需） */
  background-color: #07c160 !important;
  color: #fff !important;
  
  /* 确保按钮紧凑显示 */
  display: inline-block !important;
  box-sizing: border-box !important;
  min-width: 0 !important;
}

/* 禁用状态样式（可选，保持视觉统一） */
.code-btn[disabled] {
  background-color: #cccccc;
  color: #999999;
}

.error-message {
  font-size: 22rpx;
  color: #e74c3c;
  margin-top: 8rpx;
  margin-left: 4rpx;
}

.login-btn {
  width: 100%;
  background: linear-gradient(135deg, #e67e22 0%, #f39c12 100%);
  color: #fff;
  border: none;
  border-radius: 12rpx;
  padding: 28rpx;
  font-size: 30rpx;
  font-weight: 600;
  margin-top: 20rpx;
  box-shadow: 0 8rpx 20rpx rgba(230, 126, 34, 0.3);
  transition: all 0.3s ease;
}

.login-btn:hover {
  box-shadow: 0 12rpx 28rpx rgba(230, 126, 34, 0.4);
  transform: translateY(-2rpx);
}

.login-btn:active {
  transform: translateY(0);
}

.forgot-password {
  text-align: right;
  margin-top: 20rpx;
}

.forgot-password text {
  font-size: 24rpx;
  color: #e67e22;
  cursor: pointer;
}

.third-party-login {
  margin-top: 40rpx;
}

.divider {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.divider-line {
  flex: 1;
  height: 1rpx;
  background: #f0e6d8;
}

.divider-text {
  padding: 0 20rpx;
  font-size: 22rpx;
  color: #999;
}

.third-party-buttons {
  display: flex;
  justify-content: center;
}

.third-party-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #faf8f5;
  border: 1rpx solid #f0e6d8;
  border-radius: 12rpx;
  padding: 20rpx 40rpx;
  margin: 0 10rpx;
  transition: all 0.3s ease;
}

.third-party-btn:hover {
  background: #f5e8d3;
  transform: translateY(-2rpx);
}

.btn-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.btn-text {
  font-size: 26rpx;
  color: #666;
}

.register-link {
  text-align: center;
  margin-top: 40rpx;
  font-size: 24rpx;
  color: #666;
}

.register-btn {
  color: #e67e22;
  font-weight: 600;
  margin-left: 8rpx;
  cursor: pointer;
}

.toast {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: rgba(0, 0, 0, 0.7);
  color: #fff;
  padding: 20rpx 30rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  z-index: 9999;
}
