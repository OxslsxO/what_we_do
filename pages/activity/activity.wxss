page {
  /* Overwrite App variables for Activity Page - Warm Lilac */
  --primary: #A996CB;
  --primary-light: #D4C9E6;
  --primary-gradient: linear-gradient(135deg, #BFAEE1 0%, #A996CB 100%);
  --bg-color: #FAFAFC;
  --card-bg-gradient: linear-gradient(135deg, rgba(253, 251, 255, 1) 0%, rgba(250, 248, 252, 0.95) 100%);
  --shadow-primary: 0 12rpx 24rpx rgba(169, 150, 203, 0.25);
  --border-light: rgba(205, 194, 224, 0.3);
}

.page {
  min-height: 100vh;
  padding: 32rpx 24rpx 52rpx;
  box-sizing: border-box;
}

/* Base Cards */
.hero-card,
.task-card,
.status-card {
  padding: 40rpx 36rpx;
  border-radius: var(--radius-lg);
  background: var(--card-bg-gradient);
  border: 1rpx solid var(--border-light);
  box-shadow: var(--shadow-soft);
  margin-bottom: 32rpx;
}

/* Typography */
.hero-kicker,
.status-label,
.task-scene {
  font-size: 22rpx;
  color: var(--primary);
  letter-spacing: 2rpx;
  font-weight: 500;
}

.hero-title,
.task-title,
.status-title {
  margin-top: 16rpx;
  font-size: 52rpx;
  font-weight: bold;
  color: var(--text-main);
}

.hero-copy,
.task-copy,
.status-copy {
  margin-top: 16rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: var(--text-sub);
}

/* Specific elements */
.task-scene {
  display: inline-block;
  padding: 10rpx 24rpx;
  border-radius: var(--radius-round);
  background: rgba(169, 150, 203, 0.1);
  color: var(--primary);
}

.task-duration {
  margin-top: 20rpx;
  font-size: 24rpx;
  color: var(--primary);
  font-weight: 500;
}

.action-row {
  display: flex;
  gap: 16rpx;
  margin-top: 44rpx;
}

.warm-button,
.ghost-button {
  flex: 1;
  padding: 24rpx 0;
}
