.page {
  min-height: 100vh;
  padding: 24rpx;
  background:
    radial-gradient(circle at top left, rgba(255, 237, 198, 0.86), transparent 24%),
    linear-gradient(180deg, #fff8ee 0%, #fffdf8 56%, #f8f2e8 100%);
  box-sizing: border-box;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 22rpx;
  padding: 10rpx 6rpx;
}

.back-btn,
.placeholder {
  width: 56rpx;
}

.back-btn {
  font-size: 40rpx;
  color: #8a6644;
}

.title {
  font-size: 34rpx;
  font-weight: 700;
  color: #5d4634;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.card {
  overflow: hidden;
  border-radius: 30rpx;
  background: rgba(255, 252, 247, 0.92);
  border: 1rpx solid rgba(228, 201, 165, 0.55);
  box-shadow: 0 14rpx 30rpx rgba(171, 141, 98, 0.1);
}

.cover {
  width: 100%;
  height: 300rpx;
}

.card-body {
  padding: 24rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #5d4634;
}

.card-summary {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #8a725b;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 16rpx;
}

.tag {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 248, 236, 0.92);
  border: 1rpx solid rgba(227, 199, 160, 0.6);
  font-size: 22rpx;
  color: #82674b;
}

.card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 18rpx;
}

.meta {
  font-size: 22rpx;
  color: #9b7d5a;
}

.remove-btn {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #8b6848;
  background: rgba(255, 248, 236, 0.92);
  border: 1rpx solid rgba(227, 199, 160, 0.6);
}

.loading-text {
  text-align: center;
  padding: 20rpx 0;
  font-size: 24rpx;
  color: #9b7d5a;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 160rpx 40rpx;
}

.empty-icon {
  font-size: 120rpx;
}

.empty-title {
  margin-top: 20rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #5d4634;
}

.empty-copy {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
  text-align: center;
  color: #8a725b;
}
