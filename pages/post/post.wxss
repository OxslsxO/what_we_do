.page {
  min-height: 100vh;
  padding: 26rpx 24rpx 40rpx;
  background:
    radial-gradient(circle at top left, rgba(255, 229, 198, 0.75) 0, rgba(255, 229, 198, 0) 34%),
    linear-gradient(180deg, #fffaf3 0%, #f7f1ea 48%, #f4f5f2 100%);
  box-sizing: border-box;
}

.header,
.badge-row,
.author-row,
.tag-row,
.stats-row,
.action-row {
  display: flex;
  align-items: center;
}

.header {
  justify-content: space-between;
  height: 78rpx;
  margin-bottom: 20rpx;
}

.header-back,
.header-share {
  width: 96rpx;
  font-size: 28rpx;
  color: #846a4b;
}

.header-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #322416;
}

.header-share {
  text-align: right;
}

.detail-card {
  padding: 28rpx 24rpx 24rpx;
  border-radius: 32rpx;
  background: var(--card-bg-gradient);
  border: 1rpx solid rgba(222, 204, 180, 0.42);
  box-shadow: 0 18rpx 42rpx rgba(113, 84, 50, 0.08);
}

.badge-row,
.tag-row {
  flex-wrap: wrap;
  gap: 12rpx;
}

.module-badge,
.template-badge,
.tag-chip {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.module-badge {
  background: rgba(223, 149, 94, 0.12);
  color: #b16731;
}

.template-badge {
  background: rgba(113, 93, 73, 0.08);
  color: #6f5c49;
}

.author-row {
  gap: 16rpx;
  margin-top: 18rpx;
}

.author-avatar {
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ecd8ba 0%, #d5b287 100%);
  color: #5d4227;
  font-size: 30rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.author-avatar-image {
  width: 100%;
  height: 100%;
}

.author-info {
  flex: 1;
}

.author-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #342618;
}

.author-time {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #907c66;
}

.post-title {
  margin-top: 20rpx;
  font-size: 38rpx;
  line-height: 1.42;
  font-weight: 700;
  color: #2d2115;
}

.post-summary {
  margin-top: 14rpx;
  font-size: 28rpx;
  line-height: 1.7;
  color: #604b35;
}

.post-content {
  margin-top: 14rpx;
  font-size: 26rpx;
  line-height: 1.78;
  color: #76614a;
  white-space: pre-wrap;
}

.media-swiper {
  width: 100%;
  height: 720rpx;
  margin-top: 24rpx;
  border-radius: 28rpx;
  overflow: hidden;
  background: #efe6da;
}

.media-item {
  width: 100%;
  height: 100%;
}

.tag-row {
  margin-top: 22rpx;
}

.tag-chip {
  background: rgba(118, 144, 110, 0.12);
  color: #58704f;
}

.stats-row {
  gap: 14rpx;
  margin-top: 24rpx;
}

.stat-card {
  flex: 1;
  padding: 18rpx 12rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, rgba(255, 245, 227, 0.9), rgba(255, 251, 244, 0.9));
  text-align: center;
}

.stat-value {
  font-size: 34rpx;
  font-weight: 700;
  color: #6d4f35;
}

.stat-label {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #987958;
}

.action-row {
  gap: 12rpx;
  flex-wrap: wrap;
  margin-top: 24rpx;
}

.action-pill {
  flex: 1;
  min-width: 148rpx;
  height: 76rpx;
  border-radius: 999rpx;
  background: #f9f3ea;
  color: #6f5a44;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  font-size: 24rpx;
}

.action-emoji {
  font-size: 28rpx;
}

.empty-state {
  margin-top: 26rpx;
  padding: 96rpx 36rpx;
  border-radius: 32rpx;
  background: var(--card-bg-gradient);
  border: 1rpx solid rgba(222, 204, 180, 0.4);
  text-align: center;
}

.empty-emoji {
  font-size: 76rpx;
}

.empty-title {
  margin-top: 18rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #362818;
}

.empty-copy {
  margin-top: 14rpx;
  font-size: 25rpx;
  line-height: 1.7;
  color: #7c6850;
}
